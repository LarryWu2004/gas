# Public port exposed by Docker Compose through Nginx.
HTTP_PORT=8080

# Runtime limits.
GAS_MAX_UPLOAD_MB=50
GAS_SERVER_THREADS=8
GAS_RETENTION_DAYS=30
GAS_LOG_LEVEL=INFO
GAS_PDF_TIMEOUT_SECONDS=60

# The container image provides /usr/bin/chromium. Override only for nonstandard images.
GAS_CHROMIUM_PATH=/usr/bin/chromium

# Optional DeepSeek analysis. Leave empty to use the local summary template.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
